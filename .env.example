# Database Configuration
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/swing_trade

# Security Keys
SECRET_KEY=your-secret-key-change-in-prod-min-32-chars
ENCRYPTION_KEY=your-encryption-key-change-in-prod-min-32-chars

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@swingtradeplatform.com

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Environment
ENVIRONMENT=development
